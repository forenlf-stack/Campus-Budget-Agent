generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum TransactionType {
  INCOME
  EXPENSE
  REFUND
}

enum TransactionCategory {
  MEAL
  SNACK_DRINK
  DAILY_NECESSITY
  STUDY
  TRANSPORT
  GAME_ENTERTAINMENT
  RECHARGE_SUBSCRIPTION
  MEDICAL
  OTHER
}

enum TransactionSource {
  MANUAL
  CSV
  AGENT
}

enum AccountType {
  WECHAT
  ALIPAY
  BANK
  CASH
  OTHER
}

enum RecurrenceFrequency {
  WEEKLY
  MONTHLY
  YEARLY
}

enum MealPeriod {
  BREAKFAST
  LUNCH
  DINNER
  ALL_DAY
}

enum MealCandidateDataSource {
  MANUAL
  SEED
}

enum DecisionSource {
  HISTORY
  MENU
  SNACK
}

enum DecisionOutcome {
  PURCHASED
  ABANDONED
  REPLACED
  DELAYED
}

model UserProfile {
  id                         String           @id
  displayName                String
  email                      String           @unique
  passwordHash               String
  openingBalanceCents        Int
  balanceAsOf                DateTime
  expectedMonthlyIncomeCents Int
  monthlySpendingBudgetCents Int              @default(0)
  fixedMonthlyExpenseCents   Int
  emergencyReserveCents      Int
  savingsTargetCents         Int
  savingsTargetDate          DateTime?
  allowanceDay               Int              @default(1)
  defaultLocation            String           @default("")
  createdAt                  DateTime         @default(now())
  updatedAt                  DateTime         @updatedAt
  categoryBudgets            CategoryBudget[]
  preference                 UserPreference?
  transactions               Transaction[]    @relation("UserTransactions")
  mealCandidates             MealCandidate[]
  decisions                  DecisionRecord[]
  sessions                   UserSession[]
  accounts                   Account[]
  transfers                  AccountTransfer[]
  classificationRules        ClassificationRule[]
  recurringBills             RecurringBill[]
}

model UserSession {
  id        String      @id
  userId    String
  tokenHash String      @unique
  expiresAt DateTime
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  user      UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model CategoryBudget {
  id          String              @id
  userId      String
  category    TransactionCategory
  periodStart DateTime
  amountCents Int
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  user        UserProfile         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, category, periodStart])
  @@index([userId, periodStart])
}

model UserPreference {
  id                             String      @id
  userId                         String      @unique
  maxSingleMealCents             Int
  maxSingleSnackDrinkCents       Int
  monthlyEntertainmentLimitCents Int
  recommendedLunchPriceCents     Int         @default(0)
  weeklySnackDrinkLimit          Int         @default(0)
  weeklySnackDrinkBudgetCents    Int         @default(0)
  shoppingReminderThresholdCents Int         @default(0)
  coolingOffHours                Int         @default(0)
  priceSensitivity               String
  prioritizeNeeds                Boolean
  foodLikes                      String
  foodDislikes                   String
  foodAllergens                  String
  preferredDailyNecessities      String
  avoidedBrands                  String
  protectedCategories            String      @default("[]")
  notes                          String?
  createdAt                      DateTime    @default(now())
  updatedAt                      DateTime    @updatedAt
  user                           UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Transaction {
  id                    String               @id
  userId                String
  type                  TransactionType
  category              TransactionCategory?
  source                TransactionSource    @default(MANUAL)
  amountCents           Int
  occurredAt            DateTime
  itemName              String
  merchant              String?
  note                  String?
  isFixedExpense        Boolean              @default(false)
  originalTransactionId String?
  accountId             String?
  rawMerchant           String?
  rawItemName           String?
  rawReference          String?
  deletedAt             DateTime?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  user                  UserProfile          @relation("UserTransactions", fields: [userId], references: [id], onDelete: Cascade)
  originalTransaction   Transaction?         @relation("TransactionRefunds", fields: [originalTransactionId], references: [id], onDelete: Restrict)
  refunds               Transaction[]        @relation("TransactionRefunds")
  decision              DecisionRecord?
  account               Account?              @relation(fields: [accountId], references: [id], onDelete: SetNull)

  @@index([userId, occurredAt])
  @@index([userId, category, occurredAt])
  @@index([originalTransactionId])
  @@index([userId, deletedAt, occurredAt])
  @@index([accountId, occurredAt])
}

model Account {
  id                  String            @id
  userId              String
  name                String
  type                AccountType
  openingBalanceCents Int               @default(0)
  isDefault           Boolean           @default(false)
  enabled             Boolean           @default(true)
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  user                UserProfile       @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions        Transaction[]
  outgoingTransfers   AccountTransfer[] @relation("TransferFrom")
  incomingTransfers   AccountTransfer[] @relation("TransferTo")
  recurringBills      RecurringBill[]

  @@index([userId, enabled])
  @@unique([userId, name])
}

model AccountTransfer {
  id            String      @id
  userId        String
  fromAccountId String
  toAccountId   String
  amountCents   Int
  occurredAt    DateTime
  note          String?
  deletedAt     DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  user          UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)
  fromAccount   Account     @relation("TransferFrom", fields: [fromAccountId], references: [id], onDelete: Restrict)
  toAccount     Account     @relation("TransferTo", fields: [toAccountId], references: [id], onDelete: Restrict)

  @@index([userId, occurredAt])
  @@index([fromAccountId, occurredAt])
  @@index([toAccountId, occurredAt])
}

model ClassificationRule {
  id                 String              @id
  userId             String
  merchantPattern    String
  itemPattern        String?
  normalizedMerchant String
  category           TransactionCategory
  priority           Int                 @default(100)
  enabled            Boolean             @default(true)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  user               UserProfile         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, merchantPattern, itemPattern])
  @@index([userId, enabled, priority])
}

model RecurringBill {
  id             String               @id
  userId         String
  name           String
  type           TransactionType
  category       TransactionCategory?
  amountCents    Int
  itemName       String
  merchant       String?
  accountId      String?
  note           String?
  isFixedExpense Boolean              @default(true)
  frequency      RecurrenceFrequency
  nextDueAt      DateTime
  reminderDays   Int                  @default(3)
  enabled        Boolean              @default(true)
  lastGeneratedAt DateTime?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  user           UserProfile          @relation(fields: [userId], references: [id], onDelete: Cascade)
  account        Account?             @relation(fields: [accountId], references: [id], onDelete: SetNull)

  @@index([userId, enabled, nextDueAt])
}

model MealCandidate {
  id                String                  @id
  userId            String
  name              String
  merchant          String
  typicalPriceCents Int
  location          String
  mealPeriod        MealPeriod
  tags              String
  ingredients       String
  isSpicy           Boolean                 @default(false)
  userRating        Int?
  lastPurchasedAt   DateTime?
  priceUpdatedAt    DateTime
  dataSource        MealCandidateDataSource @default(MANUAL)
  enabled           Boolean                 @default(true)
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  user              UserProfile             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, location, mealPeriod, enabled])
  @@index([userId, enabled, updatedAt])
}

model DecisionRecord {
  id                        String          @id
  userId                    String
  idempotencyKey            String
  recommendationRunId       String
  candidateId               String
  itemName                  String
  source                    DecisionSource
  outcome                   DecisionOutcome
  recommendationType        String
  recommendationRisk        String
  recommendedPriceCents     Int
  actualPriceCents          Int?
  occurredAt                DateTime?
  transactionId             String?         @unique
  remainingBudgetAfterCents Int?
  mealRemainingAfterCents   Int?
  recommendedDailyBudgetAfterCents Int?
  savingsTargetStillOnTrack Boolean?
  createdAt                 DateTime        @default(now())
  updatedAt                 DateTime        @updatedAt
  user                      UserProfile     @relation(fields: [userId], references: [id], onDelete: Cascade)
  transaction               Transaction?    @relation(fields: [transactionId], references: [id], onDelete: Restrict)

  @@unique([userId, idempotencyKey])
  @@index([userId, createdAt])
  @@index([recommendationRunId])
}
